#!/usr/bin/env bash

# Easier navigation: .., ..., ...., ....., ~ and -
alias ..="cd .."
alias ...="cd ../.."
alias ....="cd ../../.."
alias .....="cd ../../../.."
alias ~="cd ~" # `cd` is probably faster to type though
alias -- -="cd -"

# Tool Aliases
alias cat=bat
alias gst="git status"
alias pn=pnpm
alias reload="source ~/.zshrc"
alias v=nvim
alias vi=nvim
alias vim=nvim

# Always enable colored `grep` output
# Note: `GREP_OPTIONS="--color=auto"` is deprecated, hence the alias usage.
alias grep='grep -i --color=auto'
alias fgrep='fgrep -i --color=auto'
alias egrep='egrep -i --color=auto'

# Show active network interfaces
alias ifactive="ifconfig | pcregrep -M -o '^[^\t:]+:([^\n]|\n\t)*status: active'"

# List open ports
alias ports='lsof -i -P -n | grep LISTEN'

# LS Aliases
alias ls=eza
alias ls="eza -F -gh --group-directories-first --git --icons --color-scale all --hyperlink"
alias lh='ls -d .*'
alias lD='ls -D'
alias lc='ls -1'
alias ll='ls -l'
alias la='ll -a'

# wtclone clones a repository as a hidden bare repo and creates a worktree for the default branch.
wtclone() {
	if [ -z "$1" ]; then
		echo "Usage: wtclone <repository-url> [directory]"
		return 1
	fi

	local repo_url="$1"
	local dir="${2:-${repo_url##*/}}"
	dir="${dir%.git}"

	mkdir -p "$dir" || return
	git clone --bare "$repo_url" "$dir/.bare" || return
	git -C "$dir/.bare" config remote.origin.fetch '+refs/heads/*:refs/remotes/origin/*'
	git -C "$dir/.bare" fetch origin || return
	printf 'gitdir: ./.bare\n' >"$dir/.git"

	local default_branch
	default_branch=$(git -C "$dir" symbolic-ref --short refs/remotes/origin/HEAD 2>/dev/null | sed 's|^origin/||')
	default_branch="${default_branch:-main}"

	git -C "$dir" worktree add "$default_branch" "$default_branch"
}



# audio allows switching of the audio input and output from the command line
function audio() {
	if command -v -- SwitchAudioSource >/dev/null 2>&1; then
		SwitchAudioSource -t all -s "$(SwitchAudioSource -a -t all | sort -u | fzf)"
	fi
}

# speakers allows switching of the audio output from the command line
function speakers() {
	if command -v -- SwitchAudioSource >/dev/null 2>&1; then
		SwitchAudioSource -s "$(SwitchAudioSource -a -t output | fzf)"
	fi
}

# mic allows switching of the audio input from the command line
function mic() {
	if command -v -- SwitchAudioSource >/dev/null 2>&1; then
		SwitchAudioSource -t input -s "$(SwitchAudioSource -a -t input | fzf)"
	fi
}

function localserver() {
	python3 -m http.server 8000
}
