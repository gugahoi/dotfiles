#!/usr/bin/env bash

# Easier navigation: .., ..., ...., ....., ~ and -
alias ..="cd .."
alias ...="cd ../.."
alias ....="cd ../../.."
alias .....="cd ../../../.."
alias ~="cd ~" # `cd` is probably faster to type though
alias -- -="cd -"

# Tool Aliases
alias cat=bat
alias gst="git status"
alias pn=pnpm
alias reload="source ~/.zshrc"
alias v=nvim
alias vi=nvim
alias vim=nvim

# Always enable colored `grep` output
# Note: `GREP_OPTIONS="--color=auto"` is deprecated, hence the alias usage.
alias grep='grep -i --color=auto'
alias fgrep='fgrep -i --color=auto'
alias egrep='egrep -i --color=auto'

# Show active network interfaces
alias ifactive="ifconfig | pcregrep -M -o '^[^\t:]+:([^\n]|\n\t)*status: active'"

# List open ports
alias ports='lsof -i -P -n | grep LISTEN'

# LS Aliases
alias ls=eza
alias ls="eza -F -gh --group-directories-first --git --icons --color-scale all --hyperlink"
alias lh='ls -d .*'
alias lD='ls -D'
alias lc='ls -1'
alias ll='ls -l'
alias la='ll -a'

# wt is a custom function to manage git worktrees using fzf for branch selection.
wt() {
    local branch
    branch=$(git branch -a --format='%(refname:short)' | sed 's|origin/||' | sort -u | fzf --prompt="Branch> ")
    [ -z "$branch" ] && return
    # Check if worktree already exists
    local existing
    existing=$(git worktree list | grep "\[$branch\]" | awk '{print $1}')
    if [ -n "$existing" ]; then
        cd "$existing" || exit
    else
        git worktree add "../$branch" "$branch" 2>/dev/null || \
        git worktree add -b "$branch" "../$branch" main
        cd "../$branch" || exit
    fi
}
