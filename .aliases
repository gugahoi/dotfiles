#!/usr/bin/env bash

# Easier navigation: .., ..., ...., ....., ~ and -
alias ..="cd .."
alias ...="cd ../.."
alias ....="cd ../../.."
alias .....="cd ../../../.."
alias ~="cd ~" # `cd` is probably faster to type though
alias -- -="cd -"

# Tool Aliases
alias cat=bat
alias gst="git status"
alias pn=pnpm
alias reload="source ~/.zshrc"
alias v=nvim
alias vi=nvim
alias vim=nvim

# Always enable colored `grep` output
# Note: `GREP_OPTIONS="--color=auto"` is deprecated, hence the alias usage.
alias grep='grep -i --color=auto'
alias fgrep='fgrep -i --color=auto'
alias egrep='egrep -i --color=auto'

# Show active network interfaces
alias ifactive="ifconfig | pcregrep -M -o '^[^\t:]+:([^\n]|\n\t)*status: active'"

# List open ports
alias ports='lsof -i -P -n | grep LISTEN'

# LS Aliases
alias ls=eza
alias ls="eza -F -gh --group-directories-first --git --icons --color-scale all --hyperlink"
alias lh='ls -d .*'
alias lD='ls -D'
alias lc='ls -1'
alias ll='ls -l'
alias la='ll -a'

# wtclone clones a repository as a hidden bare repo and creates a worktree for the default branch.
wtclone() {
	if [ -z "$1" ]; then
		echo "Usage: wtclone <repository-url> [directory]"
		return 1
	fi

	local repo_url="$1"
	local dir="${2:-${repo_url##*/}}"
	dir="${dir%.git}"

	mkdir -p "$dir" || return
	git clone --bare "$repo_url" "$dir/.bare" || return
	git -C "$dir/.bare" config remote.origin.fetch '+refs/heads/*:refs/remotes/origin/*'
	git -C "$dir/.bare" fetch origin || return
	printf 'gitdir: ./.bare\n' >"$dir/.git"

	local default_branch
	default_branch=$(git -C "$dir" symbolic-ref --short refs/remotes/origin/HEAD 2>/dev/null | sed 's|^origin/||')
	default_branch="${default_branch:-main}"

	git -C "$dir" worktree add "$default_branch" "$default_branch"
}

# wt is a custom function to manage git worktrees using fzf for branch selection.
wt() {
	local branch default_branch local_branch target_path
	branch=$(git branch -a --format='%(refname:short)' 2>/dev/null | sed 's|^origin/||' | command grep -vx HEAD | sort -u | fzf --print-query --prompt="Branch> " | awk '
		NR == 1 { query = $0; next }
		{ selected = $0 }
		END { print (selected != "" ? selected : query) }
	')
	[ -z "$branch" ] && return
	git check-ref-format --branch "$branch" >/dev/null 2>&1 || return
	local_branch=$(git branch --format='%(refname:short)' 2>/dev/null | command grep -Fx "$branch")

	local git_common_dir bare_worktree worktree_root worktree_path
	git_common_dir=$(git rev-parse --path-format=absolute --git-common-dir 2>/dev/null) || return
	bare_worktree=$(git worktree list --porcelain | awk -v common_dir="$git_common_dir" '
		$1 == "worktree" { path = substr($0, 10) }
		$1 == "bare" && path == common_dir { print path; exit }
	')
	worktree_root=${bare_worktree:-$git_common_dir}
	worktree_root=${worktree_root%/*}
	worktree_path="$worktree_root/$branch"

	# Check if worktree already exists
	local existing
	existing=$(git worktree list --porcelain | awk -v branch="$branch" '
		$1 == "worktree" { path = substr($0, 10) }
		$1 == "branch" {
			ref = $2
			sub("^refs/heads/", "", ref)
			sub("^refs/remotes/origin/", "", ref)
			if (ref == branch) { print path; exit }
		}
	')
	if [ -n "$existing" ]; then
		target_path="$existing"
	else
		if [ -d "$worktree_path" ] && git -C "$worktree_path" rev-parse --is-inside-work-tree >/dev/null 2>&1; then
			target_path="$worktree_path"
		else
			mkdir -p "${worktree_path%/*}" || return
			if [ -n "$local_branch" ]; then
				git worktree add "$worktree_path" "$branch" || return
			else
				default_branch=$(git symbolic-ref --quiet --short refs/remotes/origin/HEAD 2>/dev/null | sed 's|^origin/||')
				default_branch=${default_branch:-$(git branch --format='%(refname:short)' 2>/dev/null | command grep -Fx main)}
				default_branch=${default_branch:-$(git branch --format='%(refname:short)' 2>/dev/null | command grep -Fx master)}
				git worktree add "$worktree_path" "$branch" 2>/dev/null ||
					git worktree add -b "$branch" "$worktree_path" "$default_branch" || return
			fi
			target_path="$worktree_path"
		fi
	fi

	local session_name
	session_name=$(printf '%s' "$branch" | tr '/.:' '___')

	if [ -n "$TMUX" ]; then
		tmux has-session -t "=$session_name" 2>/dev/null || tmux new-session -d -s "$session_name" -c "$target_path" || return
		tmux switch-client -t "=$session_name"
	else
		tmux new-session -A -s "$session_name" -c "$target_path"
	fi
}

# audio allows switching of the audio input and output from the command line
function audio() {
	if command -v -- SwitchAudioSource >/dev/null 2>&1; then
		SwitchAudioSource -t all -s "$(SwitchAudioSource -a -t all | sort -u | fzf)"
	fi
}

# speakers allows switching of the audio output from the command line
function speakers() {
	if command -v -- SwitchAudioSource >/dev/null 2>&1; then
		SwitchAudioSource -s "$(SwitchAudioSource -a -t output | fzf)"
	fi
}

# mic allows switching of the audio input from the command line
function mic() {
	if command -v -- SwitchAudioSource >/dev/null 2>&1; then
		SwitchAudioSource -t input -s "$(SwitchAudioSource -a -t input | fzf)"
	fi
}
